                      </div>
                      <span className={'inline-block px-2 py-1 rounded-full text-xs font-medium ' + getEstadoColor(curso.estado)}>
                        {curso.estado.charAt(0).toUpperCase() + curso.estado.slice(1)}
                      </span>
                    </div>
                    
                    <p className="text-sm text-gray-600 dark:text-gray-400 mb-4">
                      {curso.descripcion}
                    </p>
                    
                    <div className="space-y-2 text-sm text-gray-600 dark:text-gray-400 mb-4">
                      <div className="flex justify-between">
                        <span>Profesor:</span>
                        <span className="font-medium">{curso.profesor}</span>
                      </div>
                      <div className="flex justify-between">
                        <span>Estudiantes:</span>
                        <span className="font-medium">{curso.estudiantes}</span>
                      </div>
                      <div className="flex justify-between">
                        <span>Progreso:</span>
                        <span className="font-medium">{curso.progreso}%</span>
                      </div>
                    </div>

                    <div className="w-full bg-gray-200 dark:bg-gray-700 rounded-full h-2 mb-4">
                      <div 
                        className="bg-emerald-500 h-2 rounded-full transition-all duration-300"
                        style={{ width: curso.progreso + '%' }}
                      ></div>
                    </div>

                    <div className="flex gap-2">
                      <button 
                        onClick={() => handleCourseEnter(curso.id.toString())}
                        className="flex-1 px-3 py-2 bg-emerald-600 text-white rounded-lg hover:bg-emerald-700 transition-colors text-sm"
                      >
                        <FiPlay className="w-4 h-4 inline mr-2" />
                        Ingresar
                      </button>
                      <button className="px-3 py-2 bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 rounded-lg hover:bg-gray-200 dark:hover:bg-gray-600 transition-colors">
                        <FiBookOpen className="w-4 h-4" />
                      </button>
                    </div>
                  </motion.div>
                ))}
              </div>
            </motion.div>
          )}

          {activeTab === 'grupos' && (
            <motion.div
              key="grupos"
              initial={{ opacity: 0, y: 20 }}
              animate={{ opacity: 1, y: 0 }}
              exit={{ opacity: 0, y: -20 }}
              className="space-y-6"
            >
              <div className="bg-white dark:bg-gray-800 rounded-xl p-6 border border-gray-200 dark:border-gray-700">
                <div className="flex justify-between items-center mb-6">
                  <h3 className="text-lg font-semibold text-gray-900 dark:text-white">
                    Grupos de Estudio
                  </h3>
                  <button className="flex items-center space-x-2 px-4 py-2 bg-emerald-600 text-white rounded-lg hover:bg-emerald-700 transition-colors">
                    <FiPlus className="w-4 h-4" />
                    <span>Crear Grupo</span>
                  </button>
                </div>

                <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                  {grupos.map((grupo) => (
                    <div key={grupo.id} className="p-4 border border-gray-200 dark:border-gray-700 rounded-lg hover:shadow-md transition-shadow">
                      <div className="flex items-start justify-between mb-3">
                        <div className="flex items-center space-x-3">
                          <div className="w-10 h-10 bg-gradient-to-r from-teal-500 to-emerald-600 rounded-lg flex items-center justify-center">
                            <FiUsers className="w-5 h-5 text-white" />
                          </div>
                          <div>
                            <h4 className="font-medium text-gray-900 dark:text-white text-sm">
                              {grupo.nombre}
                            </h4>
                            <p className="text-xs text-gray-500 dark:text-gray-400">{grupo.curso}</p>
                          </div>
                        </div>
                      </div>
                      
                      <div className="space-y-1 text-xs text-gray-600 dark:text-gray-400">
                        <div className="flex justify-between">
                          <span>Profesor:</span>
                          <span>{grupo.profesor}</span>
                        </div>
                        <div className="flex justify-between">
                          <span>Estudiantes:</span>
                          <span>{grupo.estudiantes}</span>
                        </div>
                        <div className="flex justify-between">
                          <span>Horario:</span>
                          <span>{grupo.horario}</span>
                        </div>
                        <div className="flex justify-between">
                          <span>Aula:</span>
                          <span>{grupo.aula}</span>
                        </div>
                      </div>

                      <button className="w-full mt-3 px-3 py-2 bg-emerald-600 text-white rounded-lg hover:bg-emerald-700 transition-colors text-sm">
                        Ver Detalles
                      </button>
                    </div>
                  ))}
                </div>
              </div>
            </motion.div>
          )}

          {activeTab === 'materiales' && (
            <motion.div
              key="materiales"
              initial={{ opacity: 0, y: 20 }}
              animate={{ opacity: 1, y: 0 }}
              exit={{ opacity: 0, y: -20 }}
              className="bg-white dark:bg-gray-800 rounded-xl p-8 border border-gray-200 dark:border-gray-700 text-center"
            >
              <FiFileText className="w-16 h-16 text-emerald-500 mx-auto mb-4" />
              <h3 className="text-xl font-semibold text-gray-900 dark:text-white mb-2">
                Materiales Educativos
              </h3>
              <p className="text-gray-600 dark:text-gray-400 mb-6">
                Gestiona documentos, presentaciones y recursos de aprendizaje
              </p>
              <button className="px-6 py-3 bg-emerald-600 text-white rounded-lg hover:bg-emerald-700 transition-colors">
                Subir Material
              </button>
            </motion.div>
          )}

          {activeTab === 'calendario' && (
            <motion.div
              key="calendario"
              initial={{ opacity: 0, y: 20 }}
              animate={{ opacity: 1, y: 0 }}
              exit={{ opacity: 0, y: -20 }}
              className="bg-white dark:bg-gray-800 rounded-xl p-8 border border-gray-200 dark:border-gray-700 text-center"
            >
              <FiCalendar className="w-16 h-16 text-emerald-500 mx-auto mb-4" />
              <h3 className="text-xl font-semibold text-gray-900 dark:text-white mb-2">
                Calendario Académico
              </h3>
              <p className="text-gray-600 dark:text-gray-400 mb-6">

import React, { useState, useEffect } from 'react';
import { motion, AnimatePresence } from 'framer-motion';
import { 
  FiBook, 
  FiUsers, 
  FiCalendar,
  FiFileText,
  FiPlus,
  FiSearch,
  FiFilter,
  FiPlay,
  FiBookOpen,
  FiLoader
} from 'react-icons/fi';

// Importar API actualizada
import courseService from './services/courseService';
import CourseDetail from './CourseDetail';

// Tipos
interface Curso {
  id: string | number;
  nombre: string;
  codigo: string;
  profesor: string;
  estudiantes: number;
  progreso: number;
  estado: string;
  descripcion: string;
  fechaInicio: string;
  fechaFin: string;
}

interface Grupo {
  id: string | number;
  nombre: string;
  curso: string;
  estudiantes: number;
  profesor: string;
  horario: string;
  aula: string;
}

export default function ModuloAcademico() {
  const [activeTab, setActiveTab] = useState('cursos');
  const [searchTerm, setSearchTerm] = useState('');
  const [filterEstado, setFilterEstado] = useState('all');
  const [cursos, setCursos] = useState<Curso[]>([]);
  const [grupos, setGrupos] = useState<Grupo[]>([]);
  const [loading, setLoading] = useState(true);
  const [error, setError] = useState<string | null>(null);
  const [selectedCourse, setSelectedCourse] = useState<string | null>(null);

  // Cargar datos reales al inicializar
  useEffect(() => {
    cargarDatos();
  }, []);

  const cargarDatos = async () => {
    try {
      setLoading(true);
      setError(null);
      
      console.log('🔄 Cargando datos académicos...');
      
      // Cargar cursos desde la API real
      const response = await courseService.getCourses();
      
      if (response.success) {
        console.log(`✅ ${response.total} cursos cargados desde ${response.source}`);
        
        // Transformar datos de la API para el componente
        const cursosTransformados: Curso[] = response.data.map((curso) => ({
          id: curso.id,
          nombre: curso.nombre,
          codigo: curso.codigo,
          profesor: curso.profesor,
          estudiantes: curso.estudiantes,
          progreso: curso.progreso,
          estado: curso.estado,
          descripcion: curso.descripcion,
          fechaInicio: curso.fecha_inicio || curso.fecha_creacion.split('T')[0],
          fechaFin: curso.fecha_fin || '2024-06-15'
        }));
        
        setCursos(cursosTransformados);
        
        if (response.source === 'database') {
          console.log('🎯 Datos obtenidos directamente de PostgreSQL');
        } else {
          console.log('⚠️ Usando datos de fallback');
        }
      } else {
        console.warn('❌ Error en respuesta API:', response.message);
        setError(response.message || 'Error obteniendo cursos');
        setCursos([]);
      }
      
    } catch (error) {
      console.error('💥 Error crítico cargando datos:', error);
      setError(`Error crítico: ${error instanceof Error ? error.message : 'Error desconocido'}`);
      setCursos([]);
    } finally {
      setLoading(false);
    }
  };

  const refrescarDatos = () => {
    cargarDatos();
  };

  const refrescarDatos = () => {
    cargarDatos();
  };

  // Filtrar cursos según búsqueda y estado
  const cursosFiltrados = cursos.filter(curso => {
    const matchSearch = curso.nombre.toLowerCase().includes(searchTerm.toLowerCase()) ||
                       curso.codigo.toLowerCase().includes(searchTerm.toLowerCase());
    const matchFilter = filterEstado === 'all' || curso.estado === filterEstado;
    return matchSearch && matchFilter;
  });

  // Filtrar grupos
  const gruposFiltrados = grupos.filter(grupo => {
    return grupo.nombre.toLowerCase().includes(searchTerm.toLowerCase()) ||
           grupo.curso.toLowerCase().includes(searchTerm.toLowerCase());
  });

  // Manejar selección de curso
  const handleCourseSelect = (courseId: string) => {
    setSelectedCourse(courseId);
  };
